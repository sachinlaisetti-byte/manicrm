# Deployment environment (production, development)
FLASK_ENV=production
FLASK_DEBUG=0

# Port binding (Render/Railway sets PORT automatically)
PORT=5000

# Database engine selection (options: mysql, sqlite, mongodb)
DB_ENGINE=sqlite

# MySQL connection settings (only used when DB_ENGINE=mysql)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=manikanta_crm
MYSQL_USER=root
MYSQL_PASSWORD=root123

# MongoDB connection URI (only used when DB_ENGINE=mongodb)
MONGO_URI=mongodb://localhost:27017/

# Google OAuth Client ID
GOOGLE_CLIENT_ID=575061568101-4lt1m9eabuv7q7jdqps1hj568b4ch4hd.apps.googleusercontent.com
